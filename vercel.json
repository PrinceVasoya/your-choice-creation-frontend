{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://your-choice-creation.runasp.net/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://your-choice-creation.runasp.net/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}