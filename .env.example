# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only — never expose in client bundle).
# Set this via Vercel Environment Variables dashboard, NOT in source files.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# The target API base url (must NOT include trailing '/api').
# Local C# API: "https://localhost:53638"
# Remote C# API: "https://your-choice-creation.runasp.net"
VITE_API_URL="https://localhost:53638"

# The location of dynamic media upload files
VITE_UPLOADS_URL="https://localhost:53638/uploads"

# Admin credentials — set in Vercel Environment Variables, never commit real values.
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_ROLE=admin

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_GENERATED_256BIT_SECRET

# Razorpay key (get from Razorpay dashboard — use test key for development)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX